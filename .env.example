# dev = open local mode, oauth = require Google/GitHub sign-in for Studio + API.
MORPH_AUTH_MODE=dev
AUTH_SECRET=replace-with-a-long-random-value

# OAuth providers. Redirect URIs: {MORPH_APP_URL}/auth/github/callback and /auth/google/callback.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

MORPH_APP_URL=http://127.0.0.1:4177

# --- Sponsor bonus tracks (configure any combination) ---

# OpenRouter — unified model gateway (vision + design reasoning)
OPENROUTER_API_KEY=
# MORPH_OPENROUTER_MODEL=openai/gpt-4o-mini
# MORPH_NVIDIA_OPENROUTER_MODEL=nvidia/nemotron-3-nano-30b-a3b

# Nebius Token Factory — transform content enrichment
NEBIUS_API_KEY=
# MORPH_NEBIUS_MODEL=Qwen/Qwen3-30B-A3B

# NVIDIA NIM — Nemotron UI reasoning (direct or via OpenRouter above)
NVIDIA_API_KEY=
# NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
# MORPH_NVIDIA_MODEL=nvidia/nemotron-4-mini-instruct

# Microsoft for Startups — Azure OpenAI + Azure Container Apps hosting
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_API_VERSION=2024-10-21

# Cloudflare — Workers AI inference + transform edge cache worker
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_AI_GATEWAY_ID=default
# CLOUDFLARE_TRANSFORM_CACHE=1

# SUSE — set automatically when running deploy/Dockerfile.suse
# MORPH_SUSE_RUNTIME=1
# MORPH_CONTAINER_BASE=opensuse

# Optional provider preference: openrouter | nebius | nvidia | microsoft | cloudflare | openai
# MORPH_AI_PROVIDER=openrouter

# Legacy OpenAI-compatible fallback
OPENAI_API_KEY=
# MORPH_AI_BASE_URL=https://api.openai.com/v1
# MORPH_VISION_MODEL=gpt-4o-mini
# MORPH_IMAGE_MODEL=dall-e-3
