# dev = open local mode, oauth = require Google/GitHub sign-in for Studio + API.
MORPH_AUTH_MODE=dev
AUTH_SECRET=replace-with-a-long-random-value

# OAuth providers. Redirect URIs: {MORPH_APP_URL}/auth/github/callback and /auth/google/callback.
# You can also paste these live in the Studio Connect panel instead of using .env.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe. Placeholder values keep billing in stub mode; real keys enable live
# Checkout sessions and signature-verified webhooks. Keep real values out of git.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_ID=price_replace_me

MORPH_APP_URL=http://127.0.0.1:4177