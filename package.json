{
  "name": "morph",
  "version": "0.1.0",
  "description": "CI and Studio review for agent-written frontend.",
  "type": "module",
  "bin": {
    "morph": "./bin/morph.js"
  },
  "scripts": {
    "init:morph": "node ./bin/morph.js init",
    "verify": "node ./bin/morph.js verify --config morph.config.json",
    "repair": "node ./bin/morph.js repair --config morph.config.json",
    "loop": "node ./bin/morph.js loop --config morph.config.json",
    "verify:demo": "node ./bin/morph.js verify --config morph.demo.config.json",
    "repair:demo": "node ./bin/morph.js repair --config morph.demo.config.json",
    "demo": "node ./scripts/demo.mjs",
    "serve": "node ./bin/morph.js serve --config morph.config.json",
    "test": "node --test"
  },
  "keywords": [
    "design-system",
    "frontend",
    "agents",
    "ci"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@buoy-design/core": "^0.3.38",
    "@metamask/eslint-plugin-design-tokens": "^1.1.1",
    "@typescript-eslint/parser": "^8.62.1",
    "axe-core": "^4.12.1",
    "eslint": "^10.6.0",
    "eslint-plugin-tailwind-palette-guard": "^0.1.3",
    "jsdom": "^29.1.1"
  }
}
