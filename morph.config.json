{
  "projectName": "Morph Product Smoke",
  "projectId": "morph-product-smoke",
  "projectRoot": "fixtures/acme-saas-clean",
  "morphDir": ".morph",
  "workspace": {
    "id": "morph-local-workspace",
    "name": "Morph Local Workspace",
    "authMode": "dev"
  },
  "tokenFiles": [
    "design-system/tokens.css"
  ],
  "scan": [
    "src/**/*.tsx"
  ],
  "componentImports": {
    "Button": "src/components/Button.tsx"
  },
  "allowedRawHtml": [],
  "gate": {
    "minScore": 95,
    "mergePolicy": "block_on_any_drift"
  },
  "report": {
    "defaultOutput": ".morph/latest-report.json"
  },
  "server": {
    "host": "127.0.0.1",
    "port": 4177
  },
  "auth": {
    "mode": "dev",
    "sessionCookieName": "morph_session"
  },
  "billing": {
    "mode": "local"
  }
}
